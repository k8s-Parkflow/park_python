.venv/
.codex/
__pycache__/
*.py[cod]
*$py.class

# Coverage artifacts
/reports/

# Ignore markdown files by default
*.md
AGENTS.md

# Keep README files anywhere
!README.md
!**/README.md

# Keep docs markdown files
!docs/**/*.md

# Ignore test documents except README files
services/*/test/*.md
services/*/test/*.txt
services/*/test/*.rst
services/*/test/**/*.md
services/*/test/**/*.txt
services/*/test/**/*.rst
!services/*/test/README.md
!services/*/test/**/README.md
